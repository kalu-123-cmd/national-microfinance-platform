# ============================================================================
# National Digital Microfinance Platform - Environment Variables
# ============================================================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env file to version control
# ============================================================================

# ----------------------------------------------------------------------------
# SPRING PROFILES
# ----------------------------------------------------------------------------
SPRING_PROFILE=dev
# Options: dev, staging, production

# ----------------------------------------------------------------------------
# DATABASE - PostgreSQL
# ----------------------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=postgres
# IMPORTANT: Change password in production!

# PostgreSQL creates these databases automatically:
# - auth_db
# - user_db
# - kyc_db
# - wallet_db
# - payment_db
# - loan_db
# - savings_db
# - cooperative_db
# - agent_db
# - credit_db
# - reporting_db
# - admin_db

# ----------------------------------------------------------------------------
# DATABASE - MongoDB
# ----------------------------------------------------------------------------
MONGO_USER=admin
MONGO_PASSWORD=admin123
# IMPORTANT: Change password in production!

# MongoDB databases (auto-created by services):
# - notification_db
# - fraud_detection_db
# - analytics_db
# - audit_db
# - offline_sync_db
# - financial_literacy_db
# - voice_banking_db
# - document_management_db

# ----------------------------------------------------------------------------
# CACHE - Redis
# ----------------------------------------------------------------------------
REDIS_PASSWORD=redis123
# IMPORTANT: Change password in production!

# ----------------------------------------------------------------------------
# MESSAGE BROKER - Kafka
# ----------------------------------------------------------------------------
KAFKA_SERVERS=kafka:29092
# Internal Docker network address

# For external connections use:
# KAFKA_SERVERS=localhost:9092

# ----------------------------------------------------------------------------
# SECURITY - JWT
# ----------------------------------------------------------------------------
JWT_SECRET=microfinance-super-secret-jwt-key-2024-national-platform
# CRITICAL: Generate a strong random secret for production!
# Example: openssl rand -base64 64

JWT_EXPIRATION_MS=86400000
# 24 hours in milliseconds

JWT_REFRESH_EXPIRATION_MS=2592000000
# 30 days in milliseconds

# ----------------------------------------------------------------------------
# SERVICE DISCOVERY
# ----------------------------------------------------------------------------
EUREKA_URL=http://discovery-server:8761/eureka/
# Internal Docker network address

# For external connections use:
# EUREKA_URL=http://localhost:8761/eureka/

# ----------------------------------------------------------------------------
# API GATEWAY
# ----------------------------------------------------------------------------
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
# Comma-separated list of allowed origins for CORS

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ----------------------------------------------------------------------------
# FILE STORAGE
# ----------------------------------------------------------------------------
FILE_UPLOAD_DIR=/app/uploads
FILE_MAX_SIZE_MB=10

# For production, use cloud storage:
# AWS_S3_BUCKET=microfinance-documents
# AWS_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ----------------------------------------------------------------------------
# EXTERNAL SERVICES
# ----------------------------------------------------------------------------

# SMS Provider (for OTP)
SMS_PROVIDER=mock
# Options: mock, twilio, africastalking, custom
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=MicroFin

# Email Provider
EMAIL_PROVIDER=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=noreply@microfinance.et
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=noreply@microfinance.et

# Payment Gateway
PAYMENT_GATEWAY=mock
# Options: mock, telebirr, cbebirr, mpesa
PAYMENT_GATEWAY_API_KEY=your-payment-gateway-key
PAYMENT_GATEWAY_MERCHANT_ID=your-merchant-id
PAYMENT_GATEWAY_CALLBACK_URL=https://api.microfinance.et/api/v1/payments/callback

# KYC Verification Provider
KYC_PROVIDER=mock
# Options: mock, smile_identity, onfido, custom
KYC_API_KEY=your-kyc-api-key

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
FEATURE_OTP_ENABLED=true
FEATURE_BIOMETRIC_AUTH_ENABLED=true
FEATURE_USSD_ENABLED=false
FEATURE_OFFLINE_MODE_ENABLED=true

# ----------------------------------------------------------------------------
# MONITORING & LOGGING
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
# Options: TRACE, DEBUG, INFO, WARN, ERROR

# Application Performance Monitoring (APM)
APM_ENABLED=false
APM_SERVER_URL=http://apm-server:8200

# Metrics
METRICS_ENABLED=true
PROMETHEUS_ENABLED=true

# ----------------------------------------------------------------------------
# BUSINESS CONFIGURATION
# ----------------------------------------------------------------------------

# Interest Rates (annual percentage)
DEFAULT_SAVINGS_INTEREST_RATE=0.05
# 5%

DEFAULT_FIXED_DEPOSIT_RATE=0.10
# 10%

DEFAULT_LOAN_INTEREST_RATE=0.18
# 18%

# Fees
TRANSACTION_FEE_PERCENTAGE=0.005
# 0.5%

WITHDRAWAL_FEE_FLAT=5.00
# 5 ETB

MINIMUM_WALLET_BALANCE=10.00
# 10 ETB

# Limits
MAX_DAILY_TRANSACTION_LIMIT=50000.00
# 50,000 ETB

MAX_SINGLE_TRANSACTION_LIMIT=25000.00
# 25,000 ETB

MAX_LOAN_AMOUNT=500000.00
# 500,000 ETB

# ----------------------------------------------------------------------------
# RETRY & CIRCUIT BREAKER
# ----------------------------------------------------------------------------
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_MS=1000

CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_MS=60000

# ----------------------------------------------------------------------------
# SCHEDULER CONFIGURATION
# ----------------------------------------------------------------------------
SCHEDULER_ENABLED=true

# Interest accrual cron (daily at midnight)
INTEREST_ACCRUAL_CRON=0 0 0 * * *

# ROSCA disbursement cron (1st of month at 9am)
ROSCA_DISBURSEMENT_CRON=0 0 9 1 * *

# Overdue loan check cron (daily at 6am)
OVERDUE_CHECK_CRON=0 0 6 * * *

# ----------------------------------------------------------------------------
# TIMEZONE
# ----------------------------------------------------------------------------
TZ=Africa/Addis_Ababa
# East Africa Time (EAT) - UTC+3

# ----------------------------------------------------------------------------
# DEVELOPMENT / DEBUGGING
# ----------------------------------------------------------------------------
DEBUG_MODE=false
SPRING_BOOT_ADMIN_ENABLED=false
ACTUATOR_EXPOSE_ALL=false

# Hot reload for development
SPRING_DEVTOOLS_RESTART_ENABLED=false

# ----------------------------------------------------------------------------
# PRODUCTION SECURITY (UNCOMMENT IN PRODUCTION)
# ----------------------------------------------------------------------------
# FORCE_HTTPS=true
# HSTS_ENABLED=true
# CSRF_ENABLED=true
# XSS_PROTECTION_ENABLED=true

# Database SSL
# DB_SSL_MODE=require
# DB_SSL_CERT=/path/to/cert.pem

# Redis SSL
# REDIS_SSL_ENABLED=true

# ----------------------------------------------------------------------------
# BACKUP CONFIGURATION
# ----------------------------------------------------------------------------
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE=0 0 2 * * *
# Daily at 2am
# BACKUP_RETENTION_DAYS=30
# BACKUP_S3_BUCKET=microfinance-backups

# ----------------------------------------------------------------------------
# COMPLIANCE & AUDIT
# ----------------------------------------------------------------------------
AUDIT_ENABLED=true
AUDIT_LOG_ALL_REQUESTS=false
AUDIT_LOG_SENSITIVE_OPERATIONS=true

# Data retention (days)
TRANSACTION_LOG_RETENTION_DAYS=2555
# 7 years for compliance

AUDIT_LOG_RETENTION_DAYS=2555
# 7 years for compliance

# ----------------------------------------------------------------------------
# LOCALIZATION
# ----------------------------------------------------------------------------
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,am,om,ti
# English, Amharic, Oromo, Tigrinya

DEFAULT_CURRENCY=ETB
# Ethiopian Birr

# ----------------------------------------------------------------------------
# CONTACT & SUPPORT
# ----------------------------------------------------------------------------
SUPPORT_EMAIL=support@microfinance.et
SUPPORT_PHONE=+251911000000
SUPPORT_HOURS=Mon-Fri 8:00-17:00 EAT

# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------
# 1. All passwords and secrets MUST be changed in production
# 2. Use strong random values for JWT_SECRET (min 256 bits)
# 3. Enable SSL/TLS for all database connections in production
# 4. Configure proper backup and disaster recovery
# 5. Enable monitoring and alerting in production
# 6. Review and adjust rate limits based on load testing
# 7. Ensure compliance with Ethiopian financial regulations
# 8. Regular security audits are recommended
